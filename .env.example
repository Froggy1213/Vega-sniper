# ==============================
# Marketplace Sniffer v2 — Environment Configuration
# ==============================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# ==============================

# --- Telegram Bot ---
# Get your token from @BotFather: https://t.me/BotFather
BOT_TOKEN=your_telegram_bot_token_here
# Get your Telegram ID from @getmyid_bot: https://t.me/getmyid_bot
ADMIN_ID=123456789

# --- PostgreSQL ---
# Credentials used by Docker Compose AND local development
POSTGRES_USER=sniffer_admin
POSTGRES_PASSWORD=choose_a_strong_password_here
POSTGRES_DB=sniffer_db

# --- RabbitMQ ---
# Credentials used by Docker Compose AND local development
RABBITMQ_USER=guest
RABBITMQ_PASS=choose_a_strong_password_here

# --- Local Development URLs ---
# These are used when running services directly on the host (without Docker).
# Inside Docker Compose, container-name URLs are constructed automatically from the vars above.
RABBITMQ_URL=amqp://guest:choose_a_strong_password_here@localhost:5672/
DATABASE_URL=postgresql+asyncpg://sniffer_admin:choose_a_strong_password_here@localhost:5432/sniffer_db

# --- Optional Settings ---
# DB_ECHO=true           # Enable SQLAlchemy query logging (spammy, default: false)
# PREMIUM_STARS_PRICE=250        # Telegram Stars price for premium (default: 250)
# PREMIUM_DURATION_DAYS=30       # Premium subscription length in days (default: 30)
# PROXIES=http://proxy1:port,http://proxy2:port   # Comma-separated proxy list for Mercari scraper
